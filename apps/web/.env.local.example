# Copy this file to `.env.local` in apps/web and fill in your values.
# Next.js automatically loads apps/web/.env.local when you run `pnpm --filter @nexis/web dev`.

# ── Supabase (from your project: Settings → API) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Where auth redirects come back to (local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only — NEVER commit real values ────────────────────────────────
# Used for privileged server work: minting branded sign-up confirmation links
# (auth.admin.generateLink). With this + RESEND_API_KEY set, the app sends its own
# verification email and Supabase's built-in "Confirm signup" email should be
# disabled in the dashboard. Without it, sign-up falls back to Supabase's email.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Email invites + verification (optional). Without these, invite links are ─
# ── shown in-app and sign-up uses Supabase's default confirmation email. ────
# Get a key at https://resend.com. The default sender works for the Resend
# account owner's own email; use a verified domain for real sending.
RESEND_API_KEY=
EMAIL_FROM=Nexis <onboarding@resend.dev>
